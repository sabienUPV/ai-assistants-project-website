---
import { randomId } from "@utils/a11y";

interface Props {
  class?: string;
  id?: string;
  position?: 'left' | 'right';
}

const { class: className, id = randomId(), position = 'right' } = Astro.props;
---

<div class:list={["dropdown-wrapper", className]}>
  <slot name="button" />

  <div id={id} popover class:list={["dropdown-menu", `is-${position}`]}>
    <ul class="dropdown-list">
      <slot name="menu-items" />
    </ul>
  </div>
</div>


<style>
  /* Shared Dropdown Logic */
  .dropdown-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  /* Make sure the direct descendant button of the slot is a popover-trigger */
  .dropdown-wrapper > :global(button) {
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    font-family: inherit;
  }

  .dropdown-wrapper > :global(button:not(.dropdown-link)) {
    color: white;
  }

  /* Popover API: https://developer.mozilla.org/en-US/docs/Web/API/Popover_API */
  .dropdown-menu {
    background-color: #1a1a1a;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.5rem;
    padding: 0.5rem;
    z-index: 50;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    
    /* Make sure all content shows properly,
    while ensuring it doesn't overflow horizontally */
    width: max-content;
    max-width: calc(100vw - 2rem);

    flex-direction: column;
    gap: 0.2rem;

    /* Popover styles */
    &[popover] {
      position: absolute;
      inset: unset; /* We need to do this to override the default popover styles */
      
      /* Use anchor positioning to position the popover relative to the button */
      /* Note: The popover API creates an implicit anchor association, so we can use anchor() without defining an explicit anchor */
      /* https://developer.mozilla.org/en-US/docs/Web/CSS/Guides/Anchor_positioning/Using#implicit_anchor_association */
      
      top: anchor(bottom, 0.2rem);

      &.is-left {
        left: anchor(left);
      }

      &.is-right {
        right: anchor(right);
      }
    }
  }

  .dropdown-menu:popover-open {
    display: flex;
  }


  /* Chevron Animation (if present) */
  .dropdown-wrapper :global(.chevron) {
    margin-top: 0.5rem; /* Adjusted for centered vertical alignment */
    transition: transform 0.2s ease;
    transform-origin: 50% 25%;
  }

  /* We use the :has selector to check if the popover is open inside the wrapper */
  .dropdown-wrapper:has(.dropdown-menu:popover-open) :global(.chevron) {
    transform: rotate(180deg);
  }

  /* --- Shared List Styling --- */
  .dropdown-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  /* --- Shared Link/Item Styling --- */
  :global(.dropdown-link) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    
    color: var(--color-text-on-secondary);
    text-decoration: none;
    font-weight: bold;
    white-space: nowrap;
    
    padding: 0.6rem 0.9rem;
    border-radius: 0.5rem;
    transition: color 0.2s ease, background-color 0.2s ease;
    cursor: pointer;
  }

  :global(.dropdown-link:hover),
  :global(.dropdown-link:focus-visible),
  :global(.dropdown-link.is-active) {
    color: white;
    background-color: rgba(255, 255, 255, 0.1);
  }

  /* --- Mobile Landscape: Switch to row layout to save vertical space --- */
  /* We use 450px to catch most phones in landscape orientation */
  @media (max-width: 790px) and (max-height: 450px) {
      .dropdown-list {
          flex-direction: row;
          flex-wrap: wrap;
          gap: 1rem;
          justify-content: center;
      }
  }
</style>